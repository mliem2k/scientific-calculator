---
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import PhoneGallery from '../components/PhoneGallery.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

import shot1 from '../assets/screenshots/screenshot-1.webp';
import shot3 from '../assets/screenshots/screenshot-3.webp';
import shot4 from '../assets/screenshots/screenshot-4.webp';
import shot5 from '../assets/screenshots/screenshot-5.webp';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Scientific Calculator — natural textbook display for Android. Free and open source." />
    <title>Scientific Calculator</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  </head>
  <body class="bg-black text-white antialiased">
    <Nav />
    <Hero heroImageSrc={shot5.src} />
    <Features />
    <PhoneGallery
      shots={[
        { src: shot5.src, alt: "Calculator main screen", label: "AMOLED" },
        { src: shot1.src, alt: "Tap-to-edit expression", label: "Tap-to-edit" },
        { src: shot3.src, alt: "Scientific functions", label: "Scientific" },
        { src: shot4.src, alt: "History panel", label: "History" },
      ]}
    />
    <Footer />
  </body>
</html>
