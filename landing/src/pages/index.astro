---
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import PhoneGallery from '../components/PhoneGallery.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

import appScreenshot from '../assets/screenshots/app-screenshot.png';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Scientific Calculator — natural textbook display for Android. Free and open source." />
    <title>Scientific Calculator</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  </head>
  <body class="bg-black text-white antialiased">
    <Nav />
    <main>
      <Hero heroImageSrc={appScreenshot.src} />
      <Features />
      <PhoneGallery
        shots={[
          { src: appScreenshot.src, alt: "Calculator main screen", label: "AMOLED" },
          { src: appScreenshot.src, alt: "Scientific functions", label: "Scientific" },
          { src: appScreenshot.src, alt: "Tap-to-edit expression", label: "Tap-to-edit" },
          { src: appScreenshot.src, alt: "History panel", label: "History" },
        ]}
      />
    </main>
    <Footer />
  </body>
</html>
