---
<section class="relative bg-black py-40 px-6 text-center overflow-hidden">
  <!-- radial glow -->
  <div class="pointer-events-none absolute inset-0 flex items-center justify-center">
    <div class="w-[600px] h-[600px] rounded-full bg-white opacity-[0.04] blur-[120px]"></div>
  </div>

  <div class="relative z-10">
    <h1 class="text-6xl font-bold mb-6 bg-gradient-to-b from-white to-[#A1A1AA] bg-clip-text text-transparent leading-tight">
      Scientific Calculator
    </h1>
    <p class="text-xl text-[#71717A] mb-12 max-w-sm mx-auto leading-relaxed">
      Natural textbook display. For Android.
    </p>
    <a
      href="https://github.com/mliem2k/scientific-calculator/releases/latest"
      class="inline-block bg-white text-black font-semibold text-lg px-10 py-4 rounded-xl shadow-[0_0_40px_rgba(255,255,255,0.15)] hover:shadow-[0_0_60px_rgba(255,255,255,0.25)] hover:scale-105 transition-all duration-200"
    >
      Download APK
    </a>
  </div>
</section>
