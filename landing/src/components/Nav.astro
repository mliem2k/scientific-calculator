---
---
<header class="fixed top-0 inset-x-0 z-50 bg-black/80 backdrop-blur-md border-b border-[#18181b]">
  <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
    <div class="flex items-center gap-2.5">
      <img src="/favicon.svg" alt="" class="w-6 h-6" />
      <span class="font-semibold text-white text-sm tracking-tight">Scientific Calculator</span>
    </div>
    <nav class="flex items-center gap-5">
      <a
        href="https://github.com/mliem2k/scientific-calculator"
        target="_blank"
        rel="noopener noreferrer"
        class="text-[#8c8c95] hover:text-white text-sm transition-colors hidden sm:block"
      >GitHub</a>
      <button
        id="dl-nav"
        type="button"
        class="bg-white text-black text-sm font-semibold px-4 py-1.5 rounded-lg hover:bg-[#e4e4e7] transition-colors disabled:opacity-60 disabled:cursor-not-allowed cursor-pointer border-none"
      >Download APK</button>

<script>
  const btn = document.getElementById('dl-nav') as HTMLButtonElement;
  btn?.addEventListener('click', async () => {
    btn.disabled = true;
    btn.textContent = 'Fetching...';
    try {
      const res = await fetch('https://api.github.com/repos/mliem2k/scientific-calculator/releases');
      const releases: { prerelease: boolean; assets: { name: string; browser_download_url: string }[] }[] = await res.json();
      const nightly = releases.find(r => r.prerelease);
      const apk = nightly?.assets?.find(a => a.name.endsWith('.apk'));
      if (!apk) throw new Error('APK not found');
      window.location.href = apk.browser_download_url;
      btn.textContent = 'Download APK';
    } catch {
      btn.textContent = 'Download failed';
    } finally {
      btn.disabled = false;
    }
  });
</script>
    </nav>
  </div>
</header>
