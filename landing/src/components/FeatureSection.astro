---
interface Props {
  headline: string;
  body: string;
  imageSrc: string;
  imageAlt: string;
  imageRight: boolean;
}

const { headline, body, imageSrc, imageAlt, imageRight } = Astro.props;
---
<section class="relative bg-black border-t border-[#27272A] py-24 px-6 overflow-hidden">
  <!-- subtle section gradient -->
  <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-[#0A0A0A] to-black"></div>

  <div class="relative z-10 max-w-5xl mx-auto flex flex-col gap-12 items-center md:grid md:grid-cols-2 md:gap-20">
    <div class={`flex justify-center ${imageRight ? 'md:order-last' : 'md:order-first'}`}>
      <!-- phone frame -->
      <div class="relative rounded-[2.5rem] border border-[#3F3F46] bg-[#09090B] p-3 shadow-[0_32px_80px_rgba(0,0,0,0.8),inset_0_1px_0_rgba(255,255,255,0.06)]">
        <img
          src={imageSrc}
          alt={imageAlt}
          class="w-[220px] rounded-[1.75rem] object-contain block"
          loading="lazy"
        />
      </div>
    </div>
    <div class="flex flex-col justify-center text-center md:text-left">
      <h2 class="text-4xl font-bold text-white mb-5 leading-tight">{headline}</h2>
      <p class="text-lg text-[#71717A] leading-relaxed">{body}</p>
    </div>
  </div>
</section>
